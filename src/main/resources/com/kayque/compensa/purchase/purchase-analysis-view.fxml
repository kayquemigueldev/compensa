<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.kayque.compensa.purchase.controller.PurchaseAnalysisController"
      spacing="28.0"
      styleClass="main-content">

    <padding>
        <Insets top="42.0"
                right="44.0"
                bottom="42.0"
                left="44.0"/>
    </padding>

    <VBox spacing="8.0">
        <Label text="Analisar compra"
               styleClass="page-title"/>

        <Label text="Entenda o custo real antes de decidir."
               styleClass="page-subtitle"/>
    </VBox>

    <HBox spacing="22.0"
          VBox.vgrow="ALWAYS">

        <VBox spacing="20.0"
              prefWidth="390.0"
              minWidth="330.0"
              styleClass="card">

            <Label text="Sobre a compra"
                   styleClass="card-title"/>

            <VBox spacing="8.0">
                <Label text="O que você quer comprar?"
                       styleClass="field-label"/>

                <TextField fx:id="purchaseNameField"
                           promptText="Ex.: Salgadinho"
                           styleClass="form-field"/>
            </VBox>

            <VBox spacing="8.0">
                <Label text="Quanto custa?"
                       styleClass="field-label"/>

                <TextField fx:id="purchasePriceField"
                           promptText="Ex.: 7,99"
                           styleClass="form-field"/>
            </VBox>

            <VBox spacing="8.0">
                <Label text="Com que frequência?"
                       styleClass="field-label"/>

                <ComboBox fx:id="frequencyComboBox"
                          maxWidth="Infinity"
                          styleClass="form-combo"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Analisar compra"
                    maxWidth="Infinity"
                    onAction="#analyzePurchase"
                    styleClass="primary-button"/>
        </VBox>

        <VBox spacing="24.0"
              maxWidth="Infinity"
              HBox.hgrow="ALWAYS"
              styleClass="card">

            <VBox spacing="9.0">
                <Label fx:id="analysisStatusLabel"
                       text="SUA DECISÃO COMEÇA AQUI"
                       styleClass="analysis-status"/>

                <Label fx:id="analysisDescriptionLabel"
                       text="Informe o produto, preço e frequência para visualizar o impacto dessa escolha."
                       wrapText="true"
                       styleClass="result-description-left"/>
            </VBox>

            <HBox spacing="14.0">

                <VBox spacing="7.0"
                      maxWidth="Infinity"
                      HBox.hgrow="ALWAYS"
                      styleClass="analysis-metric">

                    <Label text="Trabalho profissional"
                           styleClass="metric-title"/>

                    <Label fx:id="professionalTimeLabel"
                           text="--"
                           styleClass="metric-value"/>

                    <Label text="Considerando apenas sua jornada."
                           wrapText="true"
                           styleClass="metric-description"/>
                </VBox>

                <VBox spacing="7.0"
                      maxWidth="Infinity"
                      HBox.hgrow="ALWAYS"
                      styleClass="analysis-metric, analysis-metric-highlight">

                    <Label text="Tempo real"
                           styleClass="metric-title"/>

                    <Label fx:id="realTimeLabel"
                           text="--"
                           styleClass="metric-value-highlight"/>

                    <Label text="Incluindo todo o tempo comprometido."
                           wrapText="true"
                           styleClass="metric-description"/>
                </VBox>

                <VBox spacing="7.0"
                      maxWidth="Infinity"
                      HBox.hgrow="ALWAYS"
                      styleClass="analysis-metric">

                    <Label text="Projeção anual"
                           styleClass="metric-title"/>

                    <Label fx:id="yearlyCostLabel"
                           text="--"
                           styleClass="metric-value"/>

                    <Label text="Conforme a frequência informada."
                           wrapText="true"
                           styleClass="metric-description"/>
                </VBox>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="12.0"
                  styleClass="analysis-reflection">

                <Label text="Reflexão"
                       styleClass="reflection-title"/>

                <Label text="O preço mostra quanto você paga. O tempo mostra o que essa escolha realmente custa."
                       wrapText="true"
                       styleClass="reflection-text"/>
            </VBox>

            <Label fx:id="analysisFeedbackLabel"
                   text=""
                   wrapText="true"
                   styleClass="feedback-label"/>

            <Label text="A decisão continua sendo sua."
                   styleClass="decision-message"/>
        </VBox>
    </HBox>
</VBox>