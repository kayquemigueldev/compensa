<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.kayque.compensa.purchase.controller.PurchaseAnalysisController"
      spacing="24.0"
      styleClass="main-content">

    <padding>
        <Insets top="32.0"
                right="36.0"
                bottom="32.0"
                left="36.0"/>
    </padding>

    <VBox spacing="6.0">
        <Label text="Analisar compra"
               styleClass="page-title"/>

        <Label text="Entenda o custo real antes de decidir."
               styleClass="page-subtitle"/>
    </VBox>

    <HBox spacing="20.0"
          VBox.vgrow="ALWAYS">

        <VBox spacing="14.0"
              prefWidth="410.0"
              minWidth="380.0"
              styleClass="card">

            <Label text="Sobre a compra"
                   styleClass="card-title"/>

            <VBox spacing="6.0">
                <Label text="O que você quer comprar?"
                       styleClass="field-label"/>

                <TextField fx:id="purchaseNameField"
                           promptText="Ex.: Salgadinho"
                           styleClass="form-field"/>
            </VBox>

            <HBox spacing="12.0">

                <VBox spacing="6.0"
                      HBox.hgrow="ALWAYS"
                      maxWidth="Infinity">
                    <Label text="Quanto custa?"
                           styleClass="field-label"/>

                    <TextField fx:id="purchasePriceField"
                               promptText="Ex.: 7,99"
                               styleClass="form-field"/>
                </VBox>

                <VBox spacing="6.0"
                      HBox.hgrow="ALWAYS"
                      maxWidth="Infinity">
                    <Label text="Frequência"
                           styleClass="field-label"/>

                    <ComboBox fx:id="frequencyComboBox"
                              maxWidth="Infinity"
                              styleClass="form-combo"/>
                </VBox>
            </HBox>

            <Label text="Contexto da decisão"
                   styleClass="form-section-title"/>

            <HBox spacing="12.0">

                <VBox spacing="6.0"
                      HBox.hgrow="ALWAYS"
                      maxWidth="Infinity">
                    <Label text="Estava planejada?"
                           styleClass="field-label"/>

                    <ComboBox fx:id="plannedComboBox"
                              promptText="Selecione"
                              maxWidth="Infinity"
                              styleClass="form-combo"/>
                </VBox>

                <VBox spacing="6.0"
                      HBox.hgrow="ALWAYS"
                      maxWidth="Infinity">
                    <Label text="Existe alternativa?"
                           styleClass="field-label"/>

                    <ComboBox fx:id="alternativeComboBox"
                              promptText="Selecione"
                              maxWidth="Infinity"
                              styleClass="form-combo"/>
                </VBox>
            </HBox>

            <HBox spacing="12.0">

                <VBox spacing="6.0"
                      HBox.hgrow="ALWAYS"
                      maxWidth="Infinity">
                    <Label text="É urgente?"
                           styleClass="field-label"/>

                    <ComboBox fx:id="urgentComboBox"
                              promptText="Selecione"
                              maxWidth="Infinity"
                              styleClass="form-combo"/>
                </VBox>

                <VBox spacing="6.0"
                      HBox.hgrow="ALWAYS"
                      maxWidth="Infinity">
                    <Label text="Principal motivação"
                           styleClass="field-label"/>

                    <ComboBox fx:id="motivationComboBox"
                              promptText="Selecione"
                              maxWidth="Infinity"
                              styleClass="form-combo"/>
                </VBox>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Analisar compra"
                    maxWidth="Infinity"
                    onAction="#analyzePurchase"
                    styleClass="primary-button"/>
        </VBox>

        <VBox spacing="20.0"
              maxWidth="Infinity"
              HBox.hgrow="ALWAYS"
              styleClass="card">

            <VBox spacing="8.0">
                <Label fx:id="analysisStatusLabel"
                       text="SUA DECISÃO COMEÇA AQUI"
                       styleClass="analysis-status"/>

                <Label fx:id="analysisDescriptionLabel"
                       text="Informe os dados e responda às perguntas para receber uma análise consciente."
                       wrapText="true"
                       styleClass="result-description-left"/>
            </VBox>

            <HBox spacing="12.0">

                <VBox spacing="7.0"
                      maxWidth="Infinity"
                      HBox.hgrow="ALWAYS"
                      styleClass="analysis-metric">

                    <Label text="Trabalho profissional"
                           styleClass="metric-title"/>

                    <Label fx:id="professionalTimeLabel"
                           text="--"
                           styleClass="metric-value"/>
                </VBox>

                <VBox spacing="7.0"
                      maxWidth="Infinity"
                      HBox.hgrow="ALWAYS"
                      styleClass="analysis-metric, analysis-metric-highlight">

                    <Label text="Tempo real"
                           styleClass="metric-title"/>

                    <Label fx:id="realTimeLabel"
                           text="--"
                           styleClass="metric-value-highlight"/>
                </VBox>

                <VBox spacing="7.0"
                      maxWidth="Infinity"
                      HBox.hgrow="ALWAYS"
                      styleClass="analysis-metric">

                    <Label text="Projeção anual"
                           styleClass="metric-title"/>

                    <Label fx:id="yearlyCostLabel"
                           text="--"
                           styleClass="metric-value"/>

                </VBox>
            </HBox>

            <HBox spacing="16.0"
                  alignment="CENTER_LEFT"
                  styleClass="budget-impact-card">

                <VBox spacing="5.0">
                    <Label text="Impacto no orçamento mensal"
                           styleClass="metric-title"/>

                    <Label fx:id="budgetImpactDetailLabel"
                           text="Impacto no dinheiro livre"
                           wrapText="true"
                           styleClass="budget-impact-detail"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="budgetImpactPercentageLabel"
                       text="--"
                       styleClass="metric-value"/>
            </HBox>

            <VBox spacing="10.0"
                  VBox.vgrow="ALWAYS"
                  styleClass="analysis-reflection">

                <Label text="Por que chegamos a isso?"
                       styleClass="reflection-title"/>

                <Label fx:id="reflectionTextLabel"
                       text="Os fatores positivos e pontos de atenção aparecerão aqui."
                       wrapText="true"
                       styleClass="reflection-text"/>
            </VBox>

            <HBox spacing="10.0">

                <Button fx:id="purchaseDecisionButton"
                        text="Vou comprar"
                        maxWidth="Infinity"
                        HBox.hgrow="ALWAYS"
                        onAction="#choosePurchase"
                        styleClass="decision-button, decision-purchase"/>

                <Button fx:id="waitDecisionButton"
                        text="Esperar"
                        maxWidth="Infinity"
                        HBox.hgrow="ALWAYS"
                        onAction="#chooseWaiting"
                        styleClass="decision-button, decision-wait"/>

                <Button fx:id="declineDecisionButton"
                        text="Não vou comprar"
                        maxWidth="Infinity"
                        HBox.hgrow="ALWAYS"
                        onAction="#chooseDeclined"
                        styleClass="decision-button, decision-decline"/>

            </HBox>

            <Label fx:id="analysisFeedbackLabel"
                   text=""
                   wrapText="true"
                   styleClass="feedback-label"/>

            <Label text="A decisão continua sendo sua."
                   styleClass="decision-message"/>
        </VBox>
    </HBox>
</VBox>