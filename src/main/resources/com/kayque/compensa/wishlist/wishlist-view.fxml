<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.kayque.compensa.wishlist.controller.WishlistController"
      spacing="22.0"
      styleClass="main-content">

    <padding>
        <Insets top="42.0"
                right="44.0"
                bottom="42.0"
                left="44.0"/>
    </padding>

    <VBox spacing="8.0">
        <Label text="Lista de desejos"
               styleClass="page-title"/>

        <Label fx:id="wishlistSummaryLabel"
               text="Carregando compras..."
               styleClass="page-subtitle"/>
    </VBox>

    <Label fx:id="wishlistFeedbackLabel"
           text=""
           wrapText="true"
           styleClass="feedback-label"/>

    <Label fx:id="emptyStateLabel"
           text="Quando você decidir esperar antes de comprar, o item aparecerá aqui."
           visible="false"
           managed="false"
           wrapText="true"
           styleClass="history-empty-state"/>

    <ListView fx:id="wishlistListView"
              VBox.vgrow="ALWAYS"
              styleClass="wishlist-list"/>

</VBox>