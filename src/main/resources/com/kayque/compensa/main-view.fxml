<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:id="mainBorderPane"
            fx:controller="com.kayque.compensa.MainController"
            styleClass="app-root">

    <left>
        <VBox prefWidth="240.0"
              minWidth="240.0"
              styleClass="sidebar">

            <padding>
                <Insets top="32.0"
                        right="18.0"
                        bottom="24.0"
                        left="18.0"/>
            </padding>

            <VBox spacing="2.0">
                <Label text="✓  Compensa?"
                       styleClass="brand-title"/>

                <Label text="Compre consciente. Viva melhor."
                       styleClass="brand-subtitle"/>
            </VBox>

            <VBox spacing="8.0"
                  VBox.vgrow="ALWAYS"
                  styleClass="navigation">

                <Button fx:id="todayButton"
                        text="Hoje"
                        maxWidth="Infinity"
                        onAction="#showDashboard"
                        styleClass="nav-button"/>

                <Button fx:id="analyzePurchaseButton"
                        text="Analisar compra"
                        maxWidth="Infinity"
                        onAction="#showPurchaseAnalysis"
                        styleClass="nav-button-active"/>

                <Button fx:id="wishlistButton"
                        text="Lista de desejos"
                        maxWidth="Infinity"
                        onAction="#showWishlist"
                        styleClass="nav-button"/>

                <Button fx:id="historyButton"
                        text="Histórico"
                        maxWidth="Infinity"
                        onAction="#showHistory"
                        styleClass="nav-button"/>

                <Button fx:id="insightsButton"
                        text="Insights"
                        maxWidth="Infinity"
                        onAction="#showInsights"
                        styleClass="nav-button"/>

                <Region VBox.vgrow="ALWAYS"/>

                <Button fx:id="financialProfileButton"
                        text="Perfil financeiro"
                        maxWidth="Infinity"
                        onAction="#showFinancialProfile"
                        styleClass="nav-button"/>

                <Button text="Configurações"
                        maxWidth="Infinity"
                        styleClass="nav-button"/>
            </VBox>

            <VBox spacing="8.0"
                  styleClass="sidebar-message">

                <Label text="Pequenas escolhas,"
                       styleClass="sidebar-message-title"/>

                <Label text="grandes mudanças."
                       styleClass="sidebar-message-title"/>

                <Label text="Você continua no controle."
                       wrapText="true"
                       styleClass="sidebar-message-text"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <fx:include source="purchase/purchase-analysis-view.fxml"/>
    </center>

</BorderPane>