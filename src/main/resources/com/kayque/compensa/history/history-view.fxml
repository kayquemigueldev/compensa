<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.kayque.compensa.history.controller.HistoryController"
      spacing="26.0"
      styleClass="main-content">

    <padding>
        <Insets top="42.0"
                right="44.0"
                bottom="42.0"
                left="44.0"/>
    </padding>

    <VBox spacing="8.0">
        <Label text="Histórico"
               styleClass="page-title"/>

        <Label fx:id="historySummaryLabel"
               text="Carregando decisões..."
               styleClass="page-subtitle"/>
    </VBox>

    <Label fx:id="historyActionFeedbackLabel"
           text=""
           visible="false"
           managed="false"
           wrapText="true"
           styleClass="feedback-label"/>

    <HBox spacing="12.0"
          alignment="CENTER_LEFT"
          styleClass="history-toolbar">

        <TextField fx:id="historySearchField"
                   promptText="Buscar pelo nome da compra"
                   maxWidth="Infinity"
                   HBox.hgrow="ALWAYS"
                   styleClass="history-search-field"/>

        <ComboBox fx:id="historyFilterComboBox"
                  promptText="Filtrar decisões"
                  prefWidth="220.0"
                  styleClass="history-filter-combo"/>

        <Button fx:id="exportHistoryButton"
                text="Exportar CSV"
                onAction="#exportHistory"
                styleClass="history-export-button"/>

    </HBox>

    <Label fx:id="emptyStateLabel"
           text="Suas decisões aparecerão aqui depois da primeira análise."
           visible="false"
           managed="false"
           wrapText="true"
           styleClass="history-empty-state"/>

    <ListView fx:id="historyListView"
              VBox.vgrow="ALWAYS"
              styleClass="history-list"/>

</VBox>