<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.Region?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.kayque.compensa.dashboard.controller.DashboardController"
      spacing="28.0"
      styleClass="main-content">

    <padding>
        <Insets top="42.0"
                right="44.0"
                bottom="42.0"
                left="44.0"/>
    </padding>

    <VBox spacing="8.0">
        <Label fx:id="dashboardGreetingLabel"
               text="Hoje"
               styleClass="page-title"/>

        <Label text="Veja como suas decisões estão transformando sua relação com o dinheiro."
               styleClass="page-subtitle"/>
    </VBox>

    <GridPane hgap="16.0"
              vgap="16.0">

        <VBox GridPane.columnIndex="0"
              GridPane.rowIndex="0"
              maxWidth="Infinity"
              styleClass="dashboard-card">

            <Label text="Decisões analisadas"
                   styleClass="dashboard-card-title"/>

            <Label fx:id="totalDecisionsLabel"
                   text="0"
                   styleClass="dashboard-card-value"/>
        </VBox>

        <VBox GridPane.columnIndex="1"
              GridPane.rowIndex="0"
              maxWidth="Infinity"
              styleClass="dashboard-card">

            <Label text="Compras realizadas"
                   styleClass="dashboard-card-title"/>

            <Label fx:id="purchasedDecisionsLabel"
                   text="0"
                   styleClass="dashboard-card-value"/>
        </VBox>

        <VBox GridPane.columnIndex="2"
              GridPane.rowIndex="0"
              maxWidth="Infinity"
              styleClass="dashboard-card">

            <Label text="Compras evitadas"
                   styleClass="dashboard-card-title"/>

            <Label fx:id="declinedDecisionsLabel"
                   text="0"
                   styleClass="dashboard-card-value-highlight"/>
        </VBox>

        <VBox GridPane.columnIndex="3"
              GridPane.rowIndex="0"
              maxWidth="Infinity"
              styleClass="dashboard-card">

            <Label text="Aguardando decisão"
                   styleClass="dashboard-card-title"/>

            <Label fx:id="waitingDecisionsLabel"
                   text="0"
                   styleClass="dashboard-card-value-warning"/>
        </VBox>

        <VBox GridPane.columnIndex="0"
              GridPane.columnSpan="2"
              GridPane.rowIndex="1"
              maxWidth="Infinity"
              styleClass="dashboard-card-large">

            <Label text="Valor preservado"
                   styleClass="dashboard-card-title"/>

            <Label fx:id="preservedValueLabel"
                   text="R$ 0,00"
                   styleClass="dashboard-large-value"/>

            <Label text="Compras que você decidiu não realizar."
                   styleClass="dashboard-card-description"/>
        </VBox>

        <VBox GridPane.columnIndex="2"
              GridPane.columnSpan="2"
              GridPane.rowIndex="1"
              maxWidth="Infinity"
              styleClass="dashboard-card-large">

            <Label text="Tempo envolvido nas decisões"
                   styleClass="dashboard-card-title"/>

            <Label fx:id="totalWorkTimeLabel"
                   text="0 min"
                   styleClass="dashboard-large-value"/>

            <Label text="Tempo real necessário para pagar todas as compras analisadas."
                   wrapText="true"
                   styleClass="dashboard-card-description"/>
        </VBox>

    </GridPane>

    <HBox spacing="16.0">

        <VBox maxWidth="Infinity"
              HBox.hgrow="ALWAYS"
              styleClass="dashboard-card-large">

            <Label text="Planejado para escolhas"
                   styleClass="dashboard-card-title"/>

            <Label fx:id="plannedBudgetLabel"
                   text="--"
                   styleClass="dashboard-large-value"/>

            <Label text="Dinheiro livre previsto para o mês."
                   wrapText="true"
                   styleClass="dashboard-card-description"/>
        </VBox>

        <VBox maxWidth="Infinity"
              HBox.hgrow="ALWAYS"
              styleClass="dashboard-card-large">

            <Label text="Comprado neste mês"
                   styleClass="dashboard-card-title"/>

            <Label fx:id="purchasedThisMonthLabel"
                   text="--"
                   styleClass="dashboard-large-value"/>

            <Label fx:id="budgetUsagePercentageLabel"
                   text="--"
                   wrapText="true"
                   styleClass="dashboard-card-description"/>

            <ProgressBar fx:id="budgetUsageProgressBar"
                         progress="0.0"
                         maxWidth="Infinity"
                         styleClass="budget-progress-bar"/>

        </VBox>

        <VBox maxWidth="Infinity"
              HBox.hgrow="ALWAYS"
              styleClass="dashboard-card-large">

            <Label text="Disponível agora"
                   styleClass="dashboard-card-title"/>

            <Label fx:id="currentAvailableBudgetLabel"
                   text="--"
                   styleClass="dashboard-large-value"/>

            <Label text="Valor restante para novas escolhas."
                   wrapText="true"
                   styleClass="dashboard-card-description"/>
        </VBox>

    </HBox>

    <HBox spacing="16.0">

        <VBox fx:id="dashboardGoalCard"
              spacing="12.0"
              maxWidth="Infinity"
              visible="false"
              managed="false"
              HBox.hgrow="ALWAYS"
              styleClass="dashboard-goal-card">

            <HBox alignment="CENTER_LEFT">
                <VBox spacing="3.0">
                    <Label text="Sua próxima conquista"
                           styleClass="dashboard-goal-section-label"/>

                    <Label fx:id="dashboardGoalNameLabel"
                           text="Objetivo"
                           styleClass="dashboard-goal-title"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="dashboardGoalPercentageLabel"
                       text="0%"
                       styleClass="dashboard-goal-percentage"/>
            </HBox>

            <ProgressBar fx:id="dashboardGoalProgressBar"
                         progress="0.0"
                         maxWidth="Infinity"
                         styleClass="dashboard-goal-progress-bar"/>

            <HBox spacing="16.0"
                  maxWidth="Infinity">

                <VBox spacing="3.0"
                      maxWidth="Infinity"
                      HBox.hgrow="ALWAYS">

                    <Label text="Guardado"
                           styleClass="dashboard-goal-detail-label"/>

                    <Label fx:id="dashboardGoalSavedLabel"
                           text="R$ 0,00"
                           styleClass="dashboard-goal-detail-value"/>
                </VBox>

                <VBox spacing="3.0"
                      alignment="TOP_RIGHT"
                      maxWidth="Infinity"
                      HBox.hgrow="ALWAYS">

                    <Label text="Ainda falta"
                           styleClass="dashboard-goal-detail-label"/>

                    <Label fx:id="dashboardGoalRemainingLabel"
                           text="R$ 0,00"
                           styleClass="dashboard-goal-detail-highlight"/>
                </VBox>

            </HBox>

            <VBox spacing="4.0"
                  maxWidth="Infinity"
                  styleClass="dashboard-goal-forecast">

                <Label text="Previsão da conquista"
                       styleClass="dashboard-goal-forecast-caption"/>

                <Label fx:id="dashboardGoalForecastLabel"
                       text="Registre contribuições para calcular uma previsão."
                       maxWidth="Infinity"
                       wrapText="true"
                       styleClass="dashboard-goal-forecast-message"/>

                <Label fx:id="dashboardGoalForecastDateLabel"
                       text=""
                       visible="false"
                       managed="false"
                       maxWidth="Infinity"
                       wrapText="true"
                       styleClass="dashboard-goal-forecast-date"/>

            </VBox>
        </VBox>

        <VBox fx:id="dashboardHighlightCard"
              spacing="10.0"
              maxWidth="Infinity"
              HBox.hgrow="ALWAYS"
              styleClass="dashboard-insight-card, dashboard-highlight-default">

            <Label fx:id="dashboardHighlightTitleLabel"
                   text="Uma escolha de cada vez"
                   wrapText="true"
                   styleClass="dashboard-insight-title"/>

            <Label fx:id="dashboardHighlightDescriptionLabel"
                   text="O objetivo não é parar de comprar. É entender quando uma compra realmente faz sentido para você."
                   wrapText="true"
                   styleClass="dashboard-insight-text"/>
        </VBox>

    </HBox>

    <Label fx:id="dashboardFeedbackLabel"
           text=""
           styleClass="feedback-label"/>

</VBox>